Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если НЕ ЗначениеЗаполнено(Ответственный) Тогда
		Ответственный = ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
	СуммаДокумента = Товары.Итог("Сумма") + Услуги.Итог("Сумма");
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Ответственный = ПараметрыСеанса.ТекущийПользователь;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Движения.ТоварыНаСкладах.Записывать = Истина;
	Движения.УчетЗатрат.Записывать = Истина;
	Движения.Хозрасчетный.Записывать = Истина;
	
	ЗапросУП = Новый Запрос;
	ЗапросУП.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	УчетнаяПолитика.СпособСписанияЗапасов КАК СпособСписанияЗапасов
	|ИЗ
	|	Документ.УчетнаяПолитика КАК УчетнаяПолитика
	|ГДЕ
	|	УчетнаяПолитика.Проведен = ИСТИНА
	|	И УчетнаяПолитика.Дата <= &Период
	|
	|УПОРЯДОЧИТЬ ПО
	|	УчетнаяПолитика.Дата УБЫВ";
	
	ЗапросУП.УстановитьПараметр("Период", Дата);
	
	РезультатУП = ЗапросУП.Выполнить();
	
	ОтражатьСрокГодности = Ложь;
	
	Если Не РезультатУП.Пустой() Тогда
		ВыборкаУП = РезультатУП.Выбрать();
		ВыборкаУП.Следующий();
		
		Если ВыборкаУП.СпособСписанияЗапасов = Перечисления.СпособыСписанияЗапасов.FEFO Тогда
			ОтражатьСрокГодности = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПоступлениеТоваров.Номенклатура КАК Номенклатура,
	|	ПоступлениеТоваров.СрокГодности КАК СрокГодности,
	|	ПоступлениеТоваров.Количество КАК Количество,
	|	ПоступлениеТоваров.Сумма КАК Сумма
	|ИЗ
	|	Документ.ПоступлениеТоваровИУслуг.Товары КАК ПоступлениеТоваров
	|ГДЕ
	|	ПоступлениеТоваров.Ссылка = &Ссылка
	|ИТОГИ
	|	СУММА(Количество),
	|	СУММА(Сумма)
	|ПО
	|	Номенклатура,
	|	СрокГодности";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаНоменклатура = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаНоменклатура.Следующий() Цикл
		
		ВыборкаСрокГодности = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаСрокГодности.Следующий() Цикл
			
			ДвижениеТовары = Движения.ТоварыНаСкладах.Добавить();
			ДвижениеТовары.ВидДвижения = ВидДвиженияНакопления.Приход;
			ДвижениеТовары.Период = Дата;
			ДвижениеТовары.Номенклатура = ВыборкаСрокГодности.Номенклатура;
			ДвижениеТовары.Склад = Склад;
			ДвижениеТовары.Количество = ВыборкаСрокГодности.Количество;
			ДвижениеТовары.Сумма = ВыборкаСрокГодности.Сумма;
			
			Если ОтражатьСрокГодности Тогда
				ДвижениеТовары.СрокГодности = ВыборкаСрокГодности.СрокГодности;
			КонецЕсли;
			
			ДвижениеБухгалтерии = Движения.Хозрасчетный.Добавить();
			ДвижениеБухгалтерии.Период = Дата;
			ДвижениеБухгалтерии.СчетДт = ВыборкаСрокГодности.Номенклатура.СчетБухгалтерскогоУчета;
			ДвижениеБухгалтерии.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыСПоставщиками;
			ДвижениеБухгалтерии.Сумма = ВыборкаСрокГодности.Сумма;
			ДвижениеБухгалтерии.Содержание = "Отражено поступление товарно-материальных ценностей от поставщика";
			
			БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(ДвижениеБухгалтерии.СчетДт, ДвижениеБухгалтерии.СубконтоДт, ВыборкаСрокГодности.Номенклатура);
			БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(ДвижениеБухгалтерии.СчетКт, ДвижениеБухгалтерии.СубконтоКт, Контрагент);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Движения.УчетЗатрат.Записывать = Истина;
	
	ЗапросЗатраты = Новый Запрос;
	ЗапросЗатраты.Текст = 
	"ВЫБРАТЬ
	|	ПоступлениеУслуги.СтатьяЗатрат КАК СтатьяЗатрат,
	|	ПоступлениеУслуги.Услуга.СчетБухгалтерскогоУчета КАК СчетДебета,
	|	СУММА(ПоступлениеУслуги.Сумма) КАК Сумма
	|ИЗ
	|	Документ.ПоступлениеТоваровИУслуг.Услуги КАК ПоступлениеУслуги
	|ГДЕ
	|	ПоступлениеУслуги.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоступлениеУслуги.СтатьяЗатрат,
	|	ПоступлениеУслуги.Услуга.СчетБухгалтерскогоУчета";
	
	ЗапросЗатраты.УстановитьПараметр("Ссылка", Ссылка);
	
	ВыборкаЗатраты = ЗапросЗатраты.Выполнить().Выбрать();
	
	Пока ВыборкаЗатраты.Следующий() Цикл
		
		ДвижениеЗатрат = Движения.УчетЗатрат.Добавить();
		ДвижениеЗатрат.Период = Дата;
		ДвижениеЗатрат.СтатьяЗатрат = ВыборкаЗатраты.СтатьяЗатрат;
		ДвижениеЗатрат.Сумма = ВыборкаЗатраты.Сумма;
		
		ДвижениеБухгалтерии = Движения.Хозрасчетный.Добавить();
		ДвижениеБухгалтерии.Период = Дата;
		ДвижениеБухгалтерии.СчетДт = ВыборкаЗатраты.СчетДебета;
		ДвижениеБухгалтерии.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыСПоставщиками;
		ДвижениеБухгалтерии.Сумма = ВыборкаЗатраты.Сумма;
		ДвижениеБухгалтерии.Содержание = "Отражено поступление услуг от поставщика";
		
		БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(ДвижениеБухгалтерии.СчетДт, ДвижениеБухгалтерии.СубконтоДт, ВыборкаЗатраты.СтатьяЗатрат);
		БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(ДвижениеБухгалтерии.СчетКт, ДвижениеБухгалтерии.СубконтоКт, Контрагент);
		
	КонецЦикла;
	
КонецПроцедуры




