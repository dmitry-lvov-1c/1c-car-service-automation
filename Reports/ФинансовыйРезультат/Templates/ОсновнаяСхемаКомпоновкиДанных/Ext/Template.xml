		<expression>ВЫБОР 
	КОГДА Сумма(Доходы) - Сумма(Расходы) &gt; 0 
		ТОГДА "Прибыль: " + Строка(Сумма(Доходы) - Сумма(Расходы)) 
	ИНАЧЕ "Убыток: " + Строка(Сумма(Расходы) - Сумма(Доходы)) 
КОНЕЦ
</expression>
		<group>ОбщийИтог</group>
	</totalField>
