		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ТаблицаДанных.СтатьяЗатрат КАК СтатьяЗатрат,
	СУММА(ТаблицаДанных.Доходы) КАК Доходы,
	СУММА(ТаблицаДанных.Расходы) КАК Расходы
ИЗ
	(ВЫБРАТЬ
		ЕСТЬNULL(ПродажиОбороты.Номенклатура.СтатьяЗатрат, ЗНАЧЕНИЕ(Справочник.СтатьиЗатрат.ПустаяСсылка)) КАК СтатьяЗатрат,
		ПродажиОбороты.СуммаОборот КАК Доходы,
		0 КАК Расходы
	ИЗ
		РегистрНакопления.Продажи.Обороты(&amp;НачалоПериода, &amp;КонецПериода, , ) КАК ПродажиОбороты
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ЕСТЬNULL(УчетЗатратОбороты.СтатьяЗатрат, ЗНАЧЕНИЕ(Справочник.СтатьиЗатрат.ПустаяСсылка)),
		0,
		УчетЗатратОбороты.СуммаОборот
	ИЗ
		РегистрНакопления.УчетЗатрат.Обороты(&amp;НачалоПериода, &amp;КонецПериода, , ) КАК УчетЗатратОбороты) КАК ТаблицаДанных

СГРУППИРОВАТЬ ПО
	ТаблицаДанных.СтатьяЗатрат</query>
	</dataSet>
